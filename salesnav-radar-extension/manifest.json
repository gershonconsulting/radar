{
  "manifest_version": 3,
  "name": "Radar — Sales Nav Collector",
  "version": "1.5.9",
  "description": "Collects Sales Navigator connections and syncs to Radar sheet",
  "permissions": ["alarms", "storage", "scripting", "tabs", "notifications"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://script.google.com/*",
    "https://radar.gershoncrm.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://radar.gershoncrm.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "sync-core.js"
  },
  "action": {
    "default_title": "Radar Sync",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
